generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id // Wallet address
  name          String?
  bio           String?
  avatarUrl     String?
  registeredAt  DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
